# ── Supabase ──────────────────────────────────────────────────────────────
# Find these under Project Settings → API in your Supabase dashboard.
# The anon key is a public, Row-Level-Security-protected key — it is meant to
# ship to the browser, so it's safe to commit the value to Vercel env vars.
#
# Until BOTH are set, Meridian runs in design-only "preview mode": every screen
# renders, but sign-in and sync are switched off.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
